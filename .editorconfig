# EditorConfig — Đảm bảo code style nhất quán giữa các developer
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.{js,cjs,mjs}]
indent_size = 4

[*.{sh,bash}]
indent_size = 4
end_of_line = lf

[Makefile]
indent_style = tab

# ==========================================
# 0. Build Mode
# ==========================================

# ------------------------------------------
# MODE                                        ⚙️ ALL MODES
# 🇬🇧 Build mode: "new" (default) or "renew".
#    new   — Build from EJS templates (SCSS compile, WebP conversion, layout system)
#    renew — Work with existing client source (copy ALL files as-is, SCSS compile only)
# 🇯🇵 ビルドモード: "new"（デフォルト） または "renew"。
#    new   — EJSテンプレートから新規ビルド（SCSS変換、WebP変換、レイアウト）
#    renew — 既存ソースで作業（全ファイルそのままコピー、SCSSのみコンパイル）
# 🇻🇳 Chế độ build: "new" (mặc định) hoặc "renew".
#    new   — Build mới từ EJS template (SCSS, chuyển ảnh WebP, layout system)
#    renew — Nhận source khách hàng, copy TẤT CẢ file nguyên bản, chỉ compile SCSS
# ------------------------------------------
MODE=new

# ------------------------------------------
# RENEW_SCSS_DIR                              🔸 MODE=renew ONLY
# 🇬🇧 Path to SCSS source directory, relative to src/.
#    Set this to match the client's CSS directory structure.
#    You can specify multiple directories separated by commas.
#    Default: assets/scss (if left blank)
# 🇯🇵 SCSSソースディレクトリ（src/ からの相対パス）。
#    クライアントのCSS構造に合わせて設定してください。
#    カンマ区切りで複数のディレクトリを指定できます。
# 🇻🇳 Thư mục chứa SCSS, tương đối từ src/.
#    Đặt theo cấu trúc CSS của source khách hàng.
#    Hỗ trợ xuất/lắng nghe nhiều thư mục, cách nhau bằng dấu phẩy (,).
#
# 💡 Examples:
#    assets/scss                  ← 1 dir
#    PC/asb/scss, SP/asb/scss     ← Multi-dirs
# ------------------------------------------
RENEW_SCSS_DIR=assets/scss

# ------------------------------------------
# RENEW_CSS_DIR                               🔸 MODE=renew ONLY
# 🇬🇧 Path to CSS output directory, relative to public/.
#    Compiled SCSS will be placed here. Usually same folder as client's CSS.
#    Must map 1:1 with RENEW_SCSS_DIR, separated by commas.
#    Default: assets/css (if left blank)
# 🇯🇵 CSSの出力先ディレクトリ（public/ からの相対パス）。
#    コンパイルされたCSSはここに出力されます。
#    RENEW_SCSS_DIRと同じ順序でカンマ区切りで指定してください。
# 🇻🇳 Thư mục output CSS, tương đối từ public/.
#    SCSS compile xong sẽ xuất vào đây. Phải map 1:1 với RENEW_SCSS_DIR.
#    Hỗ trợ thay đổi nhiều thư mục đích, cách nhau bằng dấu phẩy (,).
#
# 💡 Examples:
#    assets/css                 ← 1 dir
#    PC/asb/css, SP/asb/css     ← Multi-dirs
# ------------------------------------------
RENEW_CSS_DIR=assets/css

# ==========================================
# 1. Output Configuration
# 🇬🇧 Only used when MODE=new. Ignored in renew mode.
# 🇯🇵 MODE=new の場合のみ有効。renew モードでは無視されます。
# 🇻🇳 Chỉ dùng khi MODE=new. Bỏ qua khi MODE=renew.
# ==========================================

# ------------------------------------------
# OUTPUT_EXT                                  ⚙️ ALL MODES
# 🇬🇧 File extension for generated pages (html or php).
#    Also controls BrowserSync: html = static server, php = proxy via local server.
# 🇯🇵 出力ファイルの拡張子（html または php）。
#    BrowserSync の動作も制御: html = 静的サーバー、php = ローカルサーバー経由プロキシ。
# 🇻🇳 Đuôi file output (html hoặc php).
#    Cũng quyết định BrowserSync: html = serve tĩnh, php = proxy qua local server.
# ------------------------------------------
OUTPUT_EXT=html

# ------------------------------------------
# USE_PHP_INCLUDE                             🔹 MODE=new ONLY
# 🇬🇧 Set true to use native "<?php include ?>" for extracting components.
# 🇯🇵 コンポーネントのインクルードに "<?php include ?>" を使用する場合は "true" にします。
# 🇻🇳 Nếu bằng true, Component sẽ được tách rời và gọi bằng mã "<?php include ?>".
# ------------------------------------------
USE_PHP_INCLUDE=true

# ==========================================
# 2. Local Server Configuration
# 🇬🇧 Auto-ignored when OUTPUT_EXT=html and MODE=new (static files served directly).
#    Only active when OUTPUT_EXT=php or MODE=renew (needs local proxy server).
# 🇯🇵 OUTPUT_EXT=html の場合は自動無視（静的ファイルを直接配信）。
#    PHP を扱う場合や renew モードの場合に設定してください。
# 🇻🇳 Tự động bỏ qua nếu là chuẩn html tĩnh thông thường.
#    Chỉ cần khai báo khi OUTPUT_EXT=php hoặc làm dự án rác renew của khách hàng.
# ==========================================

# ------------------------------------------
# PROXY_URL                                   🔹 OUTPUT_EXT=php / renew ONLY
# 🇬🇧 Access URL of your local virtual server for this project.
# 🇯🇵 このプロジェクトのローカル仮想サーバーURL。
# 🇻🇳 Đường dẫn URL Server ảo nội bộ của dự án này.
# ------------------------------------------
PROXY_URL=                       # e.g. http://localhost/template_html or http://template.test

# ------------------------------------------
# WEB_ROOT                                    ⚙️ ALL MODES
# 🇬🇧 Absolute path to your web server's document root (for npm run link).
# 🇯🇵 Web サーバーのドキュメントルートの絶対パス（npm run link 用）。
# 🇻🇳 Đường dẫn tuyệt đối tới thư mục gốc web server (để lệnh npm run link hoạt động).
# ------------------------------------------
WEB_ROOT=                        # e.g. C:\xampp\htdocs or D:\laragon\www

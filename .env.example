# ------------------------------------------
# OUTPUT_EXT                                  ⚙️ ALL MODES
# 🇬🇧 File extension for generated pages (html or php).
#    Also controls BrowserSync: html = static server, php = proxy via local server.
# 🇯🇵 出力ファイルの拡張子（html または php）。
#    BrowserSync の動作も制御: html = 静的サーバー、php = ローカルサーバー経由プロキシ。
# 🇻🇳 Đuôi file output (html hoặc php).
#    Cũng quyết định BrowserSync: html = serve tĩnh, php = proxy qua local server.
# ------------------------------------------
OUTPUT_EXT=html

# ------------------------------------------
# USE_PHP_INCLUDE                             🔹 MODE=new ONLY
# 🇬🇧 Set true to use native "<?php include ?>" for extracting components.
# 🇯🇵 コンポーネントのインクルードに "<?php include ?>" を使用する場合は "true" にします。
# 🇻🇳 Nếu bằng true, Component sẽ được tách rời và gọi bằng mã "<?php include ?>".
# ------------------------------------------
USE_PHP_INCLUDE=true

# ==========================================
# 2. Local Server Configuration
# 🇬🇧 Auto-ignored when OUTPUT_EXT=html and MODE=new (static files served directly).
#    Only active when OUTPUT_EXT=php or MODE=renew (needs local proxy server).
# 🇯🇵 OUTPUT_EXT=html の場合は自動無視（静的ファイルを直接配信）。
#    PHP を扱う場合や renew モードの場合に設定してください。
# 🇻🇳 Tự động bỏ qua nếu là chuẩn html tĩnh thông thường.
#    Chỉ cần khai báo khi OUTPUT_EXT=php hoặc làm dự án rác renew của khách hàng.
# ==========================================

# ------------------------------------------
# PROXY_URL                                   🔹 OUTPUT_EXT=php / renew ONLY
# 🇬🇧 Access URL of your local virtual server for this project.
#    If not set, auto-computed from project_dir in deploy-config.json → "{project_dir}.test"
#    Set this manually ONLY if your server uses a different URL pattern.
# 🇯🇵 このプロジェクトのローカル仮想サーバーURL。
#    未設定の場合、deploy-config.json の project_dir から自動計算 → "{project_dir}.test"
#    サーバーURLが異なる場合のみ手動で設定してください。
# 🇻🇳 URL Server ảo nội bộ. Nếu không set, tự tính từ project_dir → "{project_dir}.test"
#    Chỉ cần set thủ công nếu server ảo của anh dùng URL khác.
#
# Examples / Ví dụ:
#   Laragon / Valet : (để trống — tự động lấy project_dir.test)
#   XAMPP           : PROXY_URL=localhost/project_name
#   MAMP            : PROXY_URL=localhost:8888/project_name
#   Custom vhost    : PROXY_URL=myproject.local
# ------------------------------------------
PROXY_URL=

# ------------------------------------------
# WEB_ROOT                                    ⚙️ ALL MODES
# 🇬🇧 Absolute path to your web server's document root (for npm run link).
# 🇯🇵 Web サーバーのドキュメントルートの絶対パス（npm run link 用）。
# 🇻🇳 Đường dẫn tuyệt đối tới thư mục gốc web server (để lệnh npm run link hoạt động).
# ------------------------------------------
WEB_ROOT=                        # e.g. C:\xampp\htdocs or D:\laragon\www

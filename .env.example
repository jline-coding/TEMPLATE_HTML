# ==========================================
# 1. Output Configuration
# ==========================================

# ------------------------------------------
# OUTPUT_EXT
# 🇬🇧 File extension of the generated pages (html or php).
# 🇯🇵 最終的に出力されるファイルの拡張子を設定します（html または php）。
# 🇻🇳 Đuôi file bạn muốn hệ thống xuất ra cuối cùng (gõ: html hoặc php).
# ------------------------------------------
OUTPUT_EXT=php

# ------------------------------------------
# USE_PHP_INCLUDE
# 🇬🇧 Set true to use native "<?php include ?>" for extracting components.
# 🇯🇵 コンポーネントのインクルードに "<?php include ?>" を使用する場合は "true" にします。
# 🇻🇳 Nếu bằng true, Component sẽ được tách rời và gọi bằng mã "<?php include ?>".
# ------------------------------------------
USE_PHP_INCLUDE=true

# ==========================================
# 2. Local Server Configuration
# 🇬🇧 ONLY REQUIRED IF OUTPUT_EXT=php! If html, you can leave these blank.
# 🇯🇵 OUTPUT_EXT=php の場合のみ設定が必要です！ html の場合は空のままで構いません。
# 🇻🇳 CHỈ CẦN THIẾT LẬP KHI CHỌN OUTPUT_EXT=php! Nếu xuất html thì để trống.
# ==========================================
SERVER_TYPE=mamp                 # Options: mamp, xampp, laragon, valet
WEB_ROOT=                        # Absolute path (e.g. C:\xampp\htdocs or D:\laragon\www)

# ==========================================
# 3. Custom Proxy URL (Auto-generated by default)
# 🇬🇧 Leave blank! Auto-fetches Folder Name (e.g. http://localhost/folder_name)
# 🇯🇵 空白推奨！ フォルダ名から自動生成します（例: http://localhost/folder_name）
# 🇻🇳 Khuyên để trống! Tool tự động cấp phát URL theo Tên Thư Mục (VD: http://localhost/folder_name)
# ==========================================
PROXY_URL=                       # Only fill if using Custom Virtual Hosts (e.g. http://myproject.test)
